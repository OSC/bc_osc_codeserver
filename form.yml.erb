<%-
  groups = OodSupport::User.new.groups.sort_by(&:id).tap { |groups|
    groups.unshift(groups.delete(OodSupport::Process.group))
  }.map(&:name).grep(/^P./)
-%>
---
cluster: "pitzer"
form:
  - account
  - bc_num_hours
  - selector_one
  - selector_two
  - version
attributes:
  account:
    label: "Project"
    widget: select
    options:
      <%- groups.each do |group| %>
      - "<%= group %>"
    <%- end %>
  version:
    widget: "select"
    label: "Codeserver Version"
    options:
      - ["4.8", "4.8.3"]
      - ["3.9", "3.9.3"]
  selector_one:
    widget: "path_selector"
    label: "Selector One"
    help: "Selector One"
  selector_two:
    widget: "path_selector"
    label: "Selector TWO"
    help: "Selector TWO"
    options:
      - hidden
